# NIVA Mission Control — environment configuration
#
# Data source selector. "trello" (default) uses the live Trello API.
# "mock" uses bundled sample data so you can preview the UI with no credentials.
DATA_SOURCE=trello

# --- Trello (required when DATA_SOURCE=trello) ---
# Create a key + token at https://trello.com/power-ups/admin (or https://trello.com/app-key)
TRELLO_API_KEY=
TRELLO_TOKEN=
# The board that holds your initiatives (the id in the board URL, or the short link)
TRELLO_BOARD_ID=

# Optional: seconds to cache Trello responses server-side (default 60)
DATA_REVALIDATE_SECONDS=60
